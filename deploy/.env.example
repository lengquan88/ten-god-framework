# 形神合一微服务集群 — 环境变量配置模板
# 复制此文件为 .env (放置在项目根目录 c:\Users\41876\WorkBuddy\Claw\)
#   cp .env.example ../.env
# 然后根据实际环境修改各值

# ============================================================
# 🔴 敏感密钥（务必填写，切勿提交到 Git）
# ============================================================
DEEPSEEK_API_KEY=
IMA_OPENAPI_APIKEY=
IMA_OPENAPI_CLIENTID=
XIND_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com
OPENAI_BASE_URL=https://api.openai.com/v1

# ============================================================
# 端口配置（可自定义，避免端口冲突）
# ============================================================
GATEWAY_PORT=8000
DIALOGUE_PORT=8001
EVALUATION_PORT=8002
VISUALIZATION_PORT=8003
NGINX_HTTP_PORT=80

# ============================================================
# 日志级别: DEBUG / INFO / WARNING / ERROR
# ============================================================
LOG_LEVEL=INFO

# ============================================================
# JWT 安全配置（生产环境务必修改！）
# ============================================================
JWT_SECRET=development_secret_key_change_in_production

# ============================================================
# 评估引擎 — 动态阈值配置
# ============================================================
# ZUOWANG_THRESHOLD_MODE: dynamic（动态）或 fixed（固定0.3）
ZUOWANG_THRESHOLD_MODE=dynamic
ZUOWANG_BASE_THRESHOLD=0.3
ZUOWANG_MIN_THRESHOLD=0.12

# ============================================================
# BGE 语义嵌入模型路径（容器内路径）
# ============================================================
BGE_MODEL_PATH=/app/models/BAAI/bge-large-zh-v1___5
