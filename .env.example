# Claw - 类脑AI智能体系统
# 环境变量配置示例
# 复制此文件为 .env 并填入实际值

# ========================================
# 应用配置
# ========================================
APP_NAME=Claw
APP_VERSION=1.0.0
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO

# ========================================
# API配置
# ========================================
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true
API_WORKERS=1

# ========================================
# OpenAI配置
# ========================================
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_MODEL=gpt-4
OPENAI_TEMPERATURE=0.7
OPENAI_MAX_TOKENS=2000

# ========================================
# HuggingFace配置
# ========================================
HUGGINGFACE_API_KEY=your_huggingface_api_key_here
HUGGINGFACE_API_BASE=https://api-inference.huggingface.co
HUGGINGFACE_CACHE_DIR=~/.cache/huggingface

# ========================================
# ChromaDB配置
# ========================================
CHROMADB_HOST=localhost
CHROMADB_PORT=8001
CHROMADB_PERSIST_DIRECTORY=./data/chromadb

# ========================================
# Neo4j配置
# ========================================
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_neo4j_password_here
NEO4J_DATABASE=neo4j

# ========================================
# Redis配置
# ========================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=your_redis_password_here
REDIS_MAX_CONNECTIONS=10

# ========================================
# PostgreSQL配置
# ========================================
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=claw
POSTGRES_USER=claw_user
POSTGRES_PASSWORD=your_postgres_password_here
POSTGRES_MAX_CONNECTIONS=10

# ========================================
# MongoDB配置
# ========================================
MONGODB_URI=mongodb://localhost:27017
MONGODB_DATABASE=claw
MONGODB_USERNAME=
MONGODB_PASSWORD=

# ========================================
# RabbitMQ配置
# ========================================
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_VIRTUAL_HOST=/

# ========================================
# JWT/安全配置
# ========================================

# JWT/API密钥（用于认证，生产环境必须设置强密钥
# 使用以下命令生成密钥：
#   Windows: python -c "import secrets; print(secrets.token_hex(32))"
#   Linux/Mac: openssl rand -hex 32
JWT_SECRET_KEY=your_jwt_secret_key_here_change_this_in_production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=30

# API服务认证密钥（推荐启用，设置后所有API端点需要认证
API_SECRET_KEY=your_api_secret_key_here_change_this_in_production

# 是否启用API认证（true/false，开发时可关闭，生产必须开启）
API_REQUIRE_AUTH=true

# CORS允许的源，生产环境必须设置为具体域名
# 多个来源使用逗号分隔：http://localhost:3000,https://yourdomain.com
CORS_ALLOWED_ORIGINS=http://localhost,http://127.0.0.1

# MCP服务器API密钥（用于HTTP调试模式的认证密钥
MCP_API_KEY=your_mcp_api_key_here_change_this_in_production

# MCP服务器绑定地址（默认127.0.0.1仅本地访问，如需远程请设置为0.0.0.0（不推荐
MCP_BIND_HOST=127.0.0.1

# MCP服务器CORS来源配置
MCP_CORS_ORIGIN=http://localhost,http://127.0.0.1

# ========================================
# 文件存储配置
# ========================================
UPLOAD_DIR=./data/uploads
MAX_UPLOAD_SIZE=10485760
ALLOWED_FILE_TYPES=.jpg,.jpeg,.png,.gif,.pdf,.doc,.docx,.txt

# ========================================
# 日志配置
# ========================================
LOG_DIR=./data/logs
LOG_FILE=claw.log
LOG_ROTATION=10MB
LOG_RETENTION=30

# ========================================
# 缓存配置
# ========================================
CACHE_TYPE=redis
CACHE_DEFAULT_TIMEOUT=300
CACHE_KEY_PREFIX=claw:

# ========================================
# 任务队列配置
# ========================================
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
CELERY_TASK_SERIALIZER=json
CELERY_RESULT_SERIALIZER=json
CELERY_ACCEPT_CONTENT=json
CELERY_TIMEZONE=Asia/Shanghai

# ========================================
# 监控配置
# ========================================
PROMETHEUS_PORT=9090
PROMETHEUS_PATH=/metrics
JAEGER_AGENT_HOST=localhost
JAEGER_AGENT_PORT=6831
JAEGER_SAMPLER_TYPE=const
JAEGER_SAMPLER_PARAM=1

# ========================================
# AI模型配置
# ========================================
EMBEDDING_MODEL=text-embedding-ada-002
IMAGE_GENERATION_MODEL=stable-diffusion-xl
AUDIO_MODEL=whisper-large-v2
VISION_MODEL=gpt-4-vision-preview

# ========================================
# 智能体配置
# ========================================
MAX_AGENTS=10
AGENT_TIMEOUT=300
AGENT_MAX_RETRIES=3
AGENT_HEARTBEAT_INTERVAL=60

# ========================================
# 预测引擎配置
# ========================================
PREDICTION_MAX_HORIZON=365
PREDICTION_CONFIDENCE_LEVEL=0.95
PREDICTION_MODELS_DIR=./data/models

# ========================================
# EditFlow配置
# ===================================
EDITFLOW_MAX_DOCUMENT_SIZE=10485760
EDITFLOW_SUPPORTED_FORMATS=md,txt,pdf,docx
EDITFLOW_AUTO_SAVE_INTERVAL=60

# ========================================
# 记忆系统配置
# ========================================
MEMORY_MAX_SIZE=10000
MEMORY_RETENTION_DAYS=365
MEMORY_CACHE_SIZE=1000

# ========================================
# 安全配置
# ========================================
CORS_ORIGINS=*
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOW_HEADERS=*

RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=60

# ========================================
# 功能开关
# ========================================
FEATURE_GPU_ENABLED=false
FEATURE_DEBUGGING_ENABLED=true
FEATURE_TELEMETRY_ENABLED=false
FEATURE_ANALYTICS_ENABLED=false

# ========================================
# 第三方服务配置
# ========================================
GITHUB_TOKEN=your_github_token_here
KAGGLE_USERNAME=your_kaggle_username
KAGGLE_KEY=your_kaggle_key

# ========================================
# 开发工具配置
# ========================================
RELOAD_ENABLED=true
PROFILING_ENABLED=false
DEBUG_MODE=true
