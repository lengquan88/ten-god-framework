# ============================================================
# 🔴 敏感密钥（务必填写，切勿提交到 Git）
# ============================================================
# 使用方式：复制此文件为 .env，填入真实密钥
#   cp .env.example .env
# 加载方式：from tengod.secrets import get_secret
#   api_key = get_secret("DEEPSEEK_API_KEY")
# ============================================================

# ── DeepSeek AI ────────────────────────────────────────────
DEEPSEEK_API_KEY=

# ── IMA OpenAPI ────────────────────────────────────────────
IMA_OPENAPI_APIKEY=
IMA_OPENAPI_CLIENTID=

# ── XIND API ───────────────────────────────────────────────
XIND_API_KEY=

# ── OpenAI ─────────────────────────────────────────────────
OPENAI_API_KEY=

# ── Anthropic ──────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── API 端点（非密钥，但按需配置）─────────────────────────
ANTHROPIC_BASE_URL=https://api.anthropic.com
OPENAI_BASE_URL=https://api.openai.com/v1

# ============================================================
# 🟢 非敏感配置
# ============================================================

# ── 数据库 ─────────────────────────────────────────────────
DB_PATH=./data/knowledge.db
POSTGRES_USER=tengod
POSTGRES_PASSWORD=tengod-dev

# ── 安全 ───────────────────────────────────────────────────
JWT_SECRET=change-this-secret-in-production

# ── 日志 ───────────────────────────────────────────────────
LOG_LEVEL=INFO
