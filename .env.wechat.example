# ========================================
# Claw 微信机器人环境变量配置示例
# 复制本文件为 .env 并填写真实值
# ========================================

# ── LLM 配置（AI 智能回复）──────────────────
# OpenAI 兼容接口（也支持国内代理）
OPENAI_API_KEY=sk-your-api-key-here
LLM_MODEL=gpt-4o
# 使用国内代理时取消注释：
# OPENAI_BASE_URL=https://api.your-proxy.com/v1

# LLM 提供商（默认 openai，也支持 ollama 等）
LLM_PROVIDER=openai

# ── Redis 配置（会话存储，可选）──────────────
# 不配置 Redis 时自动使用内存存储（重启后会话丢失）
REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_PASSWORD=your-redis-password

# ── Claw 服务配置 ────────────────────────────
# Claw FastAPI 服务地址
CLAW_API_BASE=http://localhost:8000

# ── 微信配置 ─────────────────────────────────
# 每日播报时间（HH:MM 格式，北京时间）
WECHAT_BROADCAST_TIME=09:00

# 是否启用定时播报（true/false）
WECHAT_BROADCAST_ENABLED=true

# 媒体文件存储目录
WECHAT_MEDIA_DIR=data/wechat_media

# ── 白名单配置 ───────────────────────────────
# 私聊白名单（微信备注名，逗号分隔，留空=允许所有人）
WECHAT_USER_WHITELIST=张三,李四,管理员

# 群聊白名单（群名称，逗号分隔，留空=不响应任何群消息）
WECHAT_GROUP_WHITELIST=Claw测试群,AI研究群

# ── 日志配置 ─────────────────────────────────
LOG_LEVEL=INFO
