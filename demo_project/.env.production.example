# =============================================================================
# TenGod Framework 生产环境配置示例 v2.1
# =============================================================================
# 中华文明数字永生体 · 生产环境部署
# =============================================================================
# 使用方法：
#   1. 复制此文件为 .env.production
#   2. 修改所有敏感字段为真实值
#   3. 部署时使用：docker-compose --env-file .env.production up -d
# =============================================================================

# ── 应用环境 ──────────────────────────────────────────────────────────────
ENV=production
LOG_LEVEL=INFO
DEBUG=false

# ── API 配置 ──────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
API_TIMEOUT=60

# ── 安全配置（必须修改） ──────────────────────────────────────────────────
# JWT 密钥（生产环境必须设置，建议使用 openssl rand -hex 32 生成）
TENGOD_JWT_SECRET=CHANGE_ME_TO_RANDOM_64_CHAR_HEX_STRING
# API Key 鉴权（可选，留空则不启用）
TENGOD_API_KEY=

# ── Deepseek AI 配置 ──────────────────────────────────────────────────────
DEEPSEEK_API_KEY=sk-your-real-deepseek-api-key
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_TIMEOUT=60

# ── 数据库配置 ────────────────────────────────────────────────────────────
# 生产环境推荐使用 PostgreSQL
DATABASE_URL=postgresql://tengod:CHANGE_ME_PASSWORD@postgres:5432/tengod
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# ── Redis 配置 ────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD

# ── 监控配置 ──────────────────────────────────────────────────────────────
PROMETHEUS_RETENTION=15d
GRAFANA_PASSWORD=CHANGE_ME_GRAFANA_ADMIN_PASSWORD

# ── 日志配置 ──────────────────────────────────────────────────────────────
LOG_FILE=/app/logs/tengod.log
LOG_MAX_SIZE=100MB
LOG_BACKUP_COUNT=10

# ── CORS 配置 ─────────────────────────────────────────────────────────────
CORS_ORIGINS=https://your-domain.com,https://www.your-domain.com

# ── 限流配置 ──────────────────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_BURST=10

# ── 缓存配置 ──────────────────────────────────────────────────────────────
CACHE_TTL=3600
CACHE_PREFIX=tengod:

# ── 备份配置 ──────────────────────────────────────────────────────────────
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30
