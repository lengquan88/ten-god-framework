# 中华文明数字永生体 · Docker 构建上下文忽略 v2.1
# 优化构建速度和镜像大小

# ── Python 缓存 ──────────────────────────────────────────────────────────
__pycache__
*.pyc
*.pyo
*.pyd
.Python

# ── 版本控制 ──────────────────────────────────────────────────────────────
.git
.gitignore
.gitattributes

# ── 环境配置（敏感） ──────────────────────────────────────────────────────
.env
.env.local
.env.*.local

# ── 文档 ──────────────────────────────────────────────────────────────────
*.md
docs/
README*

# ── 数据和日志 ────────────────────────────────────────────────────────────
data/
logs/
backups/
*.db
*.sqlite
*.sqlite3
*.backup.*
*.log

# ── 虚拟环境 ──────────────────────────────────────────────────────────────
venv/
.venv/
env/
ENV/

# ── 测试和工具缓存 ────────────────────────────────────────────────────────
.pytest_cache/
.ruff_cache/
.coverage
htmlcov/
coverage.xml
.tox/
.mypy_cache/

# ── IDE 和编辑器 ──────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# ── 构建产物 ──────────────────────────────────────────────────────────────
build/
dist/
*.egg-info/
*.egg

# ── Docker 相关 ───────────────────────────────────────────────────────────
Dockerfile
docker-compose*.yml
.dockerignore

# ── CI/CD ─────────────────────────────────────────────────────────────────
.github/
.gitlab-ci.yml
