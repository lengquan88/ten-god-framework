# TenGod Framework v4.1.0 — 环境变量配置
# 复制此文件为 .env 并修改配置
#   cp .env.example .env

# ── 存储 ───────────────────────────────────────────────────
STORAGE_BACKEND=sqlite
TENGOD_DB_PATH=/data/tengod.db

# ── 日志 ───────────────────────────────────────────────────
LOG_LEVEL=info
LOG_FORMAT=json

# ── 认证 ───────────────────────────────────────────────────
API_KEY=
# 多密钥用逗号分隔: API_KEY=key1,key2,key3

# ── 速率限制 ───────────────────────────────────────────────
MAX_REQUESTS_PER_MINUTE=100

# ── CORS ──────────────────────────────────────────────────
ENABLE_CORS=true
CORS_ORIGINS=*

# ── 端口 ──────────────────────────────────────────────────
NGINX_PORT=80
NGINX_SSL_PORT=443

# ── 性能 ──────────────────────────────────────────────────
WORKERS=4
TIMEOUT=60

# ── 内在小孩参数 ──────────────────────────────────────────
INNER_CHILD_ALERTNESS=32.0
INNER_CHILD_PHI_LIMIT=0.8
INNER_CHILD_BETA_LIMIT=0.7
INNER_CHILD_LAMBDA=0.4
INNER_CHILD_GAMMA=0.2

# ── 门禁认知引擎 ──────────────────────────────────────────
COGNITIVE_ENGINE_URL=http://cognitive:8001
EMBEDDING_BACKEND=sentence_transformer
# 可选: sentence_transformer | tfidf_svd | torch_projection
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIM=384
VECTOR_STORE_BACKEND=sqlite_faiss
# 可选: sqlite_faiss | memory | pgvector
VECTOR_STORE_PATH=/data/vectors.db
CORPUS_PATH=/app/tengod/corpus/

# ── 门禁参数 ──────────────────────────────────────────────
GATE_THRESHOLD=0.6
ZUOWANG_THRESHOLD=0.3
RHYTHM_TAU_MIN=2
RHYTHM_TAU_MAX=6
MAX_CONTEXT_LENGTH=4096

# ── 评估参数 ──────────────────────────────────────────────
EVAL_DATASET_PATH=/data/benchmark.json
EVAL_AUTO_RUN=false