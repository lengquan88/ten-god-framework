# ============================================================================
# 中华文明数字永生体 · 环境变量配置模板
# 阶段十二：生产化部署运维
# ============================================================================
# 使用方法：
#   1. 复制此文件为 .env
#   2. 修改其中的敏感值
#   3. docker-compose up -d
# ============================================================================

# PostgreSQL 数据库
POSTGRES_USER=tengod
POSTGRES_PASSWORD=tengod_secret_2026
POSTGRES_DB=tengod

# API 配置
TENGOD_API_KEY=
TENGOD_ENV=production

# LLM 大模型配置（阶段九）
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# 日志级别
LOG_LEVEL=INFO
