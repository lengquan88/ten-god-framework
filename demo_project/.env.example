# TenGod Framework v2.0 — 环境变量配置
# 复制此文件为 .env 并修改配置
#   cp .env.example .env

# ============================================================
# 🔴 敏感密钥（务必填写，切勿提交到 Git）
# ============================================================
DEEPSEEK_API_KEY=
IMA_OPENAPI_APIKEY=
IMA_OPENAPI_CLIENTID=
XIND_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com
OPENAI_BASE_URL=https://api.openai.com/v1

# ============================================================
# 🟢 非敏感配置
# ============================================================

# ── 存储 ───────────────────────────────────────────────────
STORAGE_BACKEND=sqlite
TENGOD_DB_PATH=/data/tengod.db

# ── 日志 ───────────────────────────────────────────────────
LOG_LEVEL=info
LOG_FORMAT=json

# ── 认证 ───────────────────────────────────────────────────
API_KEY=
# 多密钥用逗号分隔: API_KEY=key1,key2,key3

# ── 速率限制 ───────────────────────────────────────────────
MAX_REQUESTS_PER_MINUTE=100

# ── CORS ──────────────────────────────────────────────────
ENABLE_CORS=true
CORS_ORIGINS=*

# ── 端口 ──────────────────────────────────────────────────
NGINX_PORT=80
NGINX_SSL_PORT=443

# ── 性能 ──────────────────────────────────────────────────
WORKERS=4
TIMEOUT=60

# ── v2.16.1 内在小孩参数 ───────────────────────────────────
INNER_CHILD_ALERTNESS=32.0
INNER_CHILD_PHI_LIMIT=0.8
INNER_CHILD_BETA_LIMIT=0.7
INNER_CHILD_LAMBDA=0.4
INNER_CHILD_GAMMA=0.2