# =============================================================================
# TenGod Framework 环境变量配置
# =============================================================================
# 中华文明数字永生体 · 环境配置示例
# =============================================================================

# ── 应用环境 ──────────────────────────────────────────────────────────────
ENV=production
LOG_LEVEL=INFO

# ── 数据库配置 ────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./data/tengod.db

# ── Redis 配置 ────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# ── Deepseek AI 配置 ──────────────────────────────────────────────────────
DEEPSEEK_API_KEY=your_api_key_here

# ── Grafana 配置 ──────────────────────────────────────────────────────────
GRAFANA_PASSWORD=admin

# ── API 配置 ──────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
